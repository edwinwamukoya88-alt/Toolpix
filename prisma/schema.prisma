generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SiteSetting {
  id                Int    @id @default(1)
  heroTitle         String @default("Smart Tools for Productivity & CBC Education")
  heroSubtitle      String @default("Free, privacy-first utilities for students, teachers, and professionals.")
  ctaPrimary        String @default("Explore Tools")
  ctaPrimaryLink    String @default("/tools")
  ctaSecondary      String @default("Read Blog")
  ctaSecondaryLink  String @default("/blog")
  defaultTitle      String @default("Zilita — Smart Tools for Productivity & Education")
  defaultDescription String @default("Free online tools for students, teachers, and professionals. Privacy-first, no sign-up required.")
  keywords          String @default("productivity tools, cbc tools, education tools, free online tools")
  ogImage           String @default("/og-image.png")
  logo              String @default("/logo.png")
  favicon           String @default("/favicon.ico")
  twitterUrl        String @default("https://twitter.com/zilita")
  githubUrl         String @default("https://github.com/edwinwamukoya88-alt")
  linkedinUrl       String @default("https://linkedin.com")
  footerText        String @default("© 2026 Zilita. All rights reserved.")
}

model ToolConfig {
  slug      String   @id
  enabled   Boolean  @default(true)
  featured  Boolean  @default(false)
  popular   Boolean  @default(false)
  new       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogDraft {
  id            String    @id
  title         String
  slug          String
  description   String    @default("")
  content       String    @default("")
  category      String    @default("Uncategorized")
  tags          String    @default("[]")
  author        String    @default("Zilita Team")
  featured      Boolean   @default(false)
  coverImage    String    @default("")
  status        String    @default("draft")
  scheduledDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminUser {
  email     String    @id
  role      String    @default("viewer")
  status    String    @default("active")
  lastLogin DateTime?
  invitedAt DateTime  @default(now())
}

model SponsoredAd {
  id          String   @id
  title       String
  description String   @default("")
  image       String?
  link        String
  slot        String   @default("hero")
  active      Boolean  @default(true)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  eventType   String
  category    String   @default("")
  name        String   @default("")
  sessionId   String   @default("")
  visitorId   String   @default("")
  path        String   @default("")
  referrer    String   @default("")
  device      String   @default("unknown")
  browser     String   @default("unknown")
  os          String   @default("unknown")
  country     String   @default("")
  properties  String   @default("{}")
  duration    Int      @default(0)
  value       Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([name])
  @@index([path])
  @@index([sessionId])
  @@index([visitorId])
  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([name, createdAt])
  @@index([path, createdAt])
}

model AnalyticsSession {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  visitorId       String   @default("")
  startTime       DateTime @default(now())
  lastActivityAt  DateTime @default(now())
  pageViews       Int      @default(0)
  toolEvents      Int      @default(0)
  aiRequests      Int      @default(0)
  blogEvents      Int      @default(0)
  device          String   @default("unknown")
  browser         String   @default("unknown")
  os              String   @default("unknown")
  country         String   @default("")
  referrer        String   @default("")

  @@index([visitorId])
  @@index([startTime])
  @@index([lastActivityAt])
  @@index([visitorId, startTime])
}

model AnalyticsVisitor {
  id              String   @id @default(cuid())
  visitorId       String   @unique
  firstVisitAt    DateTime @default(now())
  lastVisitAt     DateTime @default(now())
  totalSessions   Int      @default(0)
  totalPages      Int      @default(0)
  totalToolEvents Int      @default(0)
  totalAIRequests Int      @default(0)
  totalBlogViews  Int      @default(0)
  device          String   @default("unknown")
  browser         String   @default("unknown")
  country         String   @default("")

  @@index([lastVisitAt])
  @@index([firstVisitAt])
}

model AnalyticsDailyMetric {
  id              String   @id @default(cuid())
  date            String
  visitors        Int      @default(0)
  sessions        Int      @default(0)
  pageViews       Int      @default(0)
  toolOpens       Int      @default(0)
  toolCompletions Int      @default(0)
  aiRequests      Int      @default(0)
  aiTokensUsed    Int      @default(0)
  aiEstimatedCost Float    @default(0)
  blogViews       Int      @default(0)
  blogReads       Int      @default(0)
  newVisitors     Int      @default(0)
  bounceCount     Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model AnalyticsHourlyMetric {
  id              String   @id @default(cuid())
  date            String
  hour            Int
  visitors        Int      @default(0)
  sessions        Int      @default(0)
  pageViews       Int      @default(0)
  toolOpens       Int      @default(0)
  aiRequests      Int      @default(0)
  blogViews       Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([date, hour])
  @@index([date])
}

model AIUsageLog {
  id              String   @id @default(cuid())
  sessionId       String   @default("")
  visitorId       String   @default("")
  provider        String   @default("gemini")
  model           String   @default("")
  feature         String   @default("")
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  latencyMs       Int      @default(0)
  success         Boolean  @default(true)
  errorMessage    String   @default("")
  retryCount      Int      @default(0)
  rateLimited     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([feature])
  @@index([createdAt])
  @@index([sessionId])
  @@index([feature, createdAt])
}
